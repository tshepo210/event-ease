@model EventEase.Models.EventDashboardViewModel

<div class="container mt-4">

    <h2 class="mb-4 text-center">Event Dashboard</h2>

    <div class="row g-3">

        @foreach (var evt in Model.Events)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card shadow-sm h-100 border-0">

                    <div class="card-body">

                        <h5 class="card-title mb-1">
                            @evt.EventName
                        </h5>

                        <p class="text-muted small mb-2">
                            📅 @evt.EventDate.ToShortDateString()
                        </p>

                        <p class="mb-2">
                            📍 <strong>@evt.Venue?.VenueName</strong>
                        </p>

                        <!-- Booking Count -->
                        <div class="mb-2">
                            <span class="badge bg-primary">
                                @(evt.Booking?.Count ?? 0) Bookings
                            </span>
                        </div>

                        <!-- Booking List -->
                        <div class="small">
                            @if (evt.Booking != null && evt.Booking.Any())
                            {
                                <ul class="mb-2 ps-3">
                                    @foreach (var b in evt.Booking.Take(3))
                                    {
                                        <li>
                                            @b.BookingDate.ToShortDateString()
                                        </li>
                                    }
                                </ul>

                                @if (evt.Booking.Count > 3)
                                {
                                    <span class="text-muted">
                                        +@(evt.Booking.Count - 3) more...
                                    </span>
                                }
                            }
                            else
                            {
                                <span class="text-muted">No bookings yet</span>
                            }
                        </div>

                    </div>

                    <div class="card-footer bg-white border-0 text-end">
                        <a asp-controller="Booking"
                           asp-action="List"
                           class="btn btn-sm btn-outline-primary">
                            View Bookings
                        </a>
                    </div>

                </div>
            </div>
        }

    </div>
</div>