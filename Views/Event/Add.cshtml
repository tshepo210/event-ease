@model EventEase.Models.AddEventViewModel

<div class="container mt-4">
    <div class="card shadow-sm mx-auto" style="max-width: 420px;">

        <div class="card-header bg-primary text-white text-center">
            <h5 class="mb-0">Add Event</h5>
        </div>

        <div class="card-body">

            <form asp-action="Add" asp-controller="Event" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                <!-- Event Name -->
                <div class="mb-2">
                    <label asp-for="EventName" class="form-label"></label>
                    <input asp-for="EventName" class="form-control form-control-sm" />
                    <span asp-validation-for="EventName" class="text-danger small"></span>
                </div>

                <!-- Event Date -->
                <div class="mb-2">
                    <label asp-for="EventDate" class="form-label"></label>
                    <input asp-for="EventDate" type="date" class="form-control form-control-sm" />
                    <span asp-validation-for="EventDate" class="text-danger small"></span>
                </div>

                <!-- Description -->
                <div class="mb-2">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea asp-for="Description" class="form-control form-control-sm" rows="2"></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>

                <!-- Venue -->
                <div class="mb-3">
                    <label asp-for="VenueId" class="form-label"></label>

                    <select asp-for="VenueId" class="form-select form-select-sm">
                        <option value="">-- Select Venue --</option>
                        @foreach (var v in Model.Venues)
                        {
                            <option value="@v.VenueId">@v.VenueName</option>
                        }
                    </select>

                    <span asp-validation-for="VenueId" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-primary btn-sm w-100">
                    Submit
                </button>

            </form>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}